experiment "Anova and GLM Integration Tests" type: test {

	test "Anova Operator and Properties" {
		list<list<float>> data <- [[6.0, 8.0, 4.0, 5.0, 3.0, 4.0], [8.0, 12.0, 9.0, 11.0, 6.0, 8.0], [13.0, 9.0, 11.0, 8.0, 7.0, 12.0]];
		anova result <- anova(data);
		assert result.f_stat with_precision 2 = 9.26;
		assert result.p_value with_precision 3 = 0.002;
	}

	test "GLM Operator and Properties" {
		matrix<float> data <- matrix([[1.0, 2.0, 3.0, 4.0], [2.0, 3.0, 4.0, 2.0], [5.0, 1.0, 3.0, 5.0], [3.0, 4.0, 5.0, 1.0]]);
		regression result <- glm(data);
		assert (result.parameters[0] with_precision 5) = 0.5;
		assert (result.parameters[1] with_precision 5) = 2.5;
		assert (result.parameters[2] with_precision 5) = 0.0;
		assert (result.parameters[3] with_precision 5) = -1.5;
	}

}
