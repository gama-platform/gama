<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
      <extension
         id="gamaNature"
         name="GAMA project"
         point="org.eclipse.core.resources.natures">
      <runtime>
         <run
               class="gama.workspace.nature.GamaNature"> 
         </run>
      </runtime>
      <content-type
            id="gama.gaml.file.type">
      </content-type>
   </extension>
   
         <extension
               id="builtinNature"
               name="GAMA built-in project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.BuiltinNature">
               </run>
            </runtime>
            <requires-nature
                  id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>
         <extension
               id="pluginNature"
               name="GAMA plugin project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.PluginNature">
               </run>
            </runtime>
            <requires-nature
                  id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>

         <extension
               id="testNature"
               name="GAMA test project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.TestNature">
               </run>
            </runtime>
             <requires-nature
                   id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>
         
            <extension
         point="org.eclipse.core.contenttype.contentTypes">
      <content-type
            file-extensions="shp,SHP"
            id="gama.shapefile.type"
            name="Shapefile"
            priority="high">
      </content-type>
      <content-type
            default-charset="UTF-8"
            file-extensions="qml,QML,cpg,CPG,prj,shx,dbf,xml,sbn,sbx,qix,qpj,fix,PRJ,SHX,DBF,XML,SBN,SBX,QIX,QPJ,FIX"
            id="gama.shapefile.support.type"
            name="Shapefile support"
            priority="high">
         <property
               name="gama.support.target">
         </property>
      </content-type>
      <content-type
            file-extensions="PNG,png,GIF,gif,JPEG,jpeg,JPG,jpg,BMP,bmp,ICO,ico,TIFF,tiff,TIF,tif,ASC,asc,PGM,pgm"
            id="gama.images.file.type"
            name="Image"
            priority="high">
      </content-type>
      <content-type
            base-type="org.eclipse.core.runtime.text"
            default-charset="UTF-8"
            file-extensions="CSV,csv,TSV,tsv"
            id="gama.csv.file.type"
            name="CSV"
            priority="high">
      </content-type>
      <content-type
            base-type="org.eclipse.core.runtime.text"
            default-charset="UTF-8"
            file-extensions="gaml,experiment"
            id="gama.gaml.file.type"
            name="GAML"
            priority="high">
      </content-type>
      <content-type
            base-type="org.eclipse.core.runtime.text"
            file-extensions="html, HTML, htm, HTM, svg, SVG"
            id="gama.html.file.type"
            name="HTML (in GAMA)"
            priority="normal">
      </content-type>
      <content-type
            file-extensions="osm,OSM,pbf,PBF,bz2,BZ2,gz,GZ"
            id="gama.osm.file.type"
            name="OSM"
            priority="high">
      </content-type>
      <content-type
            default-charset="UTF-8"
            file-extensions="svg,SVG"
            id="gama.svg.file.type"
            name="SVG File"
            priority="high">
      </content-type>
      <content-type
            default-charset="UTF-8"
            file-extensions="json,JSON,geojson,GEOJSON"
            id="gama.json.file.type"
            name="JSON File"
            priority="high">
      </content-type>
   </extension>

</plugin>