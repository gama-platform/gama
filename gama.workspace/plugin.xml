<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
      <extension
         id="gamaNature"
         name="GAMA project"
         point="org.eclipse.core.resources.natures">
      <runtime>
         <run
               class="gama.workspace.nature.GamaNature"> 
         </run>
      </runtime>
      <content-type
            id="gama.ui.gaml.type">
      </content-type>
   </extension>
   
         <extension
               id="builtinNature"
               name="GAMA built-in project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.BuiltinNature">
               </run>
            </runtime>
            <requires-nature
                  id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>
         <extension
               id="pluginNature"
               name="GAMA plugin project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.PluginNature">
               </run>
            </runtime>
            <requires-nature
                  id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>

         <extension
               id="testNature"
               name="GAMA test project"
               point="org.eclipse.core.resources.natures">
            <runtime>
               <run
                     class="gama.workspace.nature.TestNature">
               </run>
            </runtime>
             <requires-nature
                   id="gama.workspace.gamaNature">
            </requires-nature>
         </extension>

</plugin>
